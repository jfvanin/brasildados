    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.17",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "scripts": {
